{
  "name": "@overleaf/llm-agent",
  "description": "LLM agent research layer for Overleaf",
  "private": true,
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "nodemon": "node --watch app.js",
    "test:acceptance": "npm run test:acceptance:_run -- --grep=$MOCHA_GREP",
    "test:acceptance:_run": "mocha --require test/setup.js --recursive --timeout 15000 --exit test/acceptance"
  },
  "dependencies": {
    "@overleaf/logger": "*",
    "@overleaf/metrics": "*",
    "@overleaf/mongo-utils": "*",
    "@overleaf/settings": "*",
    "express": "4.22.1",
    "mongodb": "6.12.0"
  },
  "devDependencies": {
    "chai": "^4.3.6",
    "chai-as-promised": "^7.1.1",
    "mocha": "^11.1.0"
  },
  "version": "1.0.0",
  "license": "AGPL-3.0"
}
