#!/usr/bin/env bash

grep_cmd="grep"
if command -v ggrep >/dev/null 2>&1; then
  grep_cmd="ggrep"
fi

docker compose logs --follow --tail 10 --no-color "$@" \
  | "$grep_cmd" --line-buffered --invert-match "global.gc" \
  | "$grep_cmd" --line-buffered --invert-match "health.check" \
  | "$grep_cmd" --line-buffered --invert-match "slow event loop" \
  | "$grep_cmd" --line-buffered --invert-match "process.memoryUsage" \
  | "$grep_cmd" --line-buffered --only-matching "[{].*" \
  | {
    if command -v bunyan >/dev/null 2>&1; then
      bunyan --output short
    else
      cat
    fi
  }
