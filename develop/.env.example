# Copy to develop/.env (gitignored) and fill in.
# Loaded automatically by docker compose for variable substitution.

# Portkey unified gateway
PORTKEY_API_KEY=
# Optional — virtual-key route or full Portkey config id
PORTKEY_VIRTUAL_KEY=
PORTKEY_CONFIG=
# Optional — self-hosted gateway
PORTKEY_BASE_URL=

# Default generation model passed to Portkey (e.g. @deepseek/deepseek-v4-flash, gpt-4o, ...)
LLM_MODEL=@deepseek/deepseek-v4-flash
# Default model used by the LLM-as-judge evaluator (defaults to LLM_MODEL if unset)
LLM_JUDGE_MODEL=
